# =========================
# APPLICATION
# =========================
APP_NAME=Eventra
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000/

# =========================
# DATABASE
# =========================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=eventra_db
DB_USERNAME=eventra
DB_PASSWORD=Eventra@@12345

# =========================
# GOOGLE OAUTH
# =========================
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:80/api/auth/google-signin.php

# =========================
# GOOGLE MAPS
# =========================
GOOGLE_MAPS_API_KEY='YOUR_GOOGLE_MAPS_API_KEY'

# =========================
# MAIL (Optional)
# =========================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=YOUR_MAIL_USERNAME
MAIL_PASSWORD=YOUR_MAIL_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=YOUR_MAIL_FROM_ADDRESS
MAIL_FROM_NAME=Eventra

# =========================
# FILE UPLOADS
# =========================
UPLOAD_MAX_SIZE=15M
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,webp,avif

# =========================
# SECURITY
# =========================
CSRF_TOKEN_EXPIRY=3600
SESSION_LIFETIME=7200

# =========================
# PAYMENTS (PAYSTACK)
# =========================
PAYSTACK_PUBLIC_KEY=YOUR_PAYSTACK_PUBLIC_KEY
PAYSTACK_SECRET_KEY=YOUR_PAYSTACK_SECRET_KEY

# =========================
# TERMII
# =========================
TERMII_API_KEY=YOUR_TERMII_API_KEY
TERMII_SECRET_KEY=YOUR_TERMII_SECRET_KEY
TERMII_SENDER_ID=N-Alert

# =========================
# CRON
# =========================
CRON_SECRET=50a7838a3038b407ec22ea7a796fb382c1b73880bbda46ce89fee26ba1e90e82
