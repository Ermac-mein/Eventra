# ===========================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ===========================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file with real secrets to version control
# ALWAYS use strong, unique values for production

# =========================
# APPLICATION
# =========================
APP_NAME=Eventra
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourapp.com/

# =========================
# DATABASE
# =========================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=eventra_db
DB_USERNAME=eventra
DB_PASSWORD=your_secure_db_password_here

# =========================
# SESSIONS & SECURITY
# =========================
SESSION_LIFETIME=7200
SESSION_SECURE_COOKIE=true
SESSION_HTTPONLY_COOKIE=true
SESSION_SAMESITE=strict
JWT_SECRET=your_jwt_secret_key_here_generate_with_openssl_rand
QR_SECRET=your_qr_secret_key_here_generate_with_openssl_rand
CRON_SECRET=your_cron_secret_key_here_generate_with_openssl_rand

# =========================
# GOOGLE OAUTH
# =========================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://yourapp.com/api/auth/google-signin.php

# =========================
# GOOGLE MAPS
# =========================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# =========================
# EMAIL CONFIGURATION
# =========================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password_here
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourapp.com
MAIL_FROM_NAME=Eventra

# =========================
# SMS CONFIGURATION (Termii or Africa's Talking)
# =========================
SMS_PROVIDER=termii
TERMII_API_KEY=your_termii_api_key_here
TERMII_SECRET_KEY=your_termii_secret_key_here
TERMII_SENDER_ID=N-Alert

# Alternative: Africa's Talking
# SMS_PROVIDER=africas_talking
# AFRICAS_TALKING_API_KEY=your_api_key_here
# AFRICAS_TALKING_USERNAME=your_username_here

# =========================
# FILE UPLOADS
# =========================
UPLOAD_MAX_SIZE=15M
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,webp,avif
UPLOAD_SCAN_ONLY=true

# =========================
# PAYMENTS (PAYSTACK)
# =========================
PAYSTACK_PUBLIC_KEY=pk_live_your_public_key_here
PAYSTACK_SECRET_KEY=sk_live_your_secret_key_here

# =========================
# SECURITY & CSRF
# =========================
CSRF_TOKEN_EXPIRY=3600

# =========================
# IDENTITY VERIFICATION (DOJAH)
# =========================
DOJAH_API_KEY=your_dojah_api_key_here
DOJAH_ENVIRONMENT=production

# =========================
# TIMEZONE & LOCALIZATION
# =========================
DEFAULT_TIMEZONE=Africa/Lagos
DEFAULT_CURRENCY=NGN

# =========================
# LOGGING & DEBUG
# =========================
LOG_LEVEL=error
LOG_CHANNEL=stack
LOG_ERROR_ROTATION_SIZE=10M
LOG_RETENTION_DAYS=30
