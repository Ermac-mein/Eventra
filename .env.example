# =========================
# APPLICATION
# =========================
APP_NAME=Eventra
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

# =========================
# DATABASE
# =========================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=eventra_db
DB_USERNAME=root
DB_PASSWORD=

# =========================
# GOOGLE OAUTH
# =========================
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost/api/auth/google-signin.php

# =========================
# GOOGLE MAPS
# =========================
GOOGLE_MAPS_API_KEY='your_google_maps_api_key_here'

# =========================
# MAIL (Optional)
# =========================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your_email@gmail.com
MAIL_FROM_NAME=Eventra

# =========================
# FILE UPLOADS
# =========================
UPLOAD_MAX_SIZE=15M
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,webp,avif

# =========================
# SECURITY
# =========================
CSRF_TOKEN_EXPIRY=3600
SESSION_LIFETIME=7200

# =========================
# PAYMENTS (PAYSTACK)
# =========================
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here

# =========================
# TERMII
# =========================
TERMII_API_KEY=your_termii_api_key_here
TERMII_SECRET_KEY=your_termii_secret_key_here
TERMII_SENDER_ID=N-Alert

# =========================
# CRON
# =========================
CRON_SECRET=your_cron_secret_here
